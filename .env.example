# Atlas environment template. Copy to `.env` and fill in real values.
# `.env` is gitignored; this template is safe to commit so contributors
# know what variables the build expects.

# Anthropic API key used by atlas-build's summarizer pass.
# Generate at https://console.anthropic.com/ → API Keys.
# In CI, this is supplied as a repository secret named ANTHROPIC_API_KEY.
ANTHROPIC_API_KEY=
