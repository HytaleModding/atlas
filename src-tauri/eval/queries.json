{
  "schema_version": 1,
  "description": "Golden query set for Atlas search-quality evaluation. Each entry pairs a realistic user query with one or more expected hit paths. A query 'hits' if any expected_top_paths value is a suffix of an actual result path. Top-1 / Top-3 / MRR are computed against this set. Grow this file as new query patterns are discovered - the eval runner is forward-compatible with arbitrary entries.",
  "categories": {
    "symbol": "Exact class name lookups. The canonical declaration should be #1.",
    "method": "Method-shaped NL queries. Expected file is the one that DEFINES the action, not files that consume it.",
    "topical": "Broader NL queries about a feature area. Multiple files acceptable; the package as a whole is the right answer.",
    "concept": "How-do-I queries phrased as a developer would. Tests whether semantic matching connects intent to implementation.",
    "negative": "Gibberish queries that should return zero (or near-zero) hits. Validates the kNN distance threshold and BM25 floor."
  },
